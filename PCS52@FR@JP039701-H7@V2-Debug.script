			{
				// пњљпњљ26пњљF00пњљ»Впњљ1пњљAпњљпњљпњљпњљ»КOпњљпњљ0
				if (ETH_MID_CHKVALUE1("00") == 1)
				{
					fVTValue[0] = 1;
				}
