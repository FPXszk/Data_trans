	// пњљпњљ51
	RUN_MEAS_IMAGE_FSYNC(syncCycle, duty, 2000);
	// FSYNCпњљўПпњљћПкНЗпњљќМпњљпњљ@пњљпњљпњљZпњљbпњљg
