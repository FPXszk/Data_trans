	// пњљпњљпњљпњљпњљ“ВпњљпњљF1s
	WAIT(1000);
	
	USB_POW_VOLT(PWR1, 0.0);
	WAIT(POW_WAIT);
	
//	SEQ3	пњљIпњљпњљ
	
	// пњљпњљпњљпњљпњљпњљпњљ»Впњљ
	
