/*-----------------------------------------------------
	STEP 890 
-----------------------------------------------------*/
StartStep 890, 60000, cmTimeoutAbort
#include	LOCALPARAMS
#include	LOCALMACROS

	etherBaseLog.Write("////////// STEP 890 //////////");
	etherMidLog.Write("////////// STEP 890 //////////");
	
	double i2c_max[1];
	double i2c_ave[1];
	double i2c_min[1];
	
	bool i2c_kt[2];
	for (int i = 0; i < sizeof(i2c_kt); i++)
	{
		i2c_kt[i] = false;
	}
	
//	SEQ1	I2Cпњљ РMпњљпњљпњљxпњљmпњљF
	
	// пњљпњљ54
	CHECK_I2C_SPEED("GVIF1-4", &i2c_max[0], &i2c_ave[0], &i2c_min[0]);
	fVTValue[0] = i2c_ave[0] * 0.001;
	JUDGE_VT(STD_890_I2C_O_KT, 0);
	
//	SEQ2	I2Cпњљ РMпњљпњљпњљxпњљmпњљF
//	SEQ3	I2Cпњљ РMпњљпњљпњљxпњљmпњљF
	
	// NoteпњљFпњљnпњљ[пњљhпњљoпњљпњљпњљ≈СпњљпњљMпњљRпњљ}пњљпњљпњљhпњљћХѕЙпњљпњљ…Тпњљпњљпњљ
	// MidпњљFi2c_kt_mid
	ETH_MID_SEND("./" CMD_i2c_kt_mid);
	do
	{
		ETH_MID_RECV(ETH_TIMEOUT, false);
		
		if (!i2c_kt[0])
		{
			ETH_MID_RESETPOINTER();
			if (ETH_MID_CHKRECV(RES_i2c_kt_mid_CH5, false) == 0)
			{
				fVTValue[0] = ETH_MID_GETDECIMAL("kbps");
				i2c_kt[0] = true;
			}
		}
		
		if (!i2c_kt[1])
		{
			ETH_MID_RESETPOINTER();
			if (ETH_MID_CHKRECV(RES_i2c_kt_mid_CH1, false) == 0)
			{
				fVTValue[1] = ETH_MID_GETDECIMAL("kbps");
				i2c_kt[1] = true;
			}
		}
	}
	while (!i2c_kt[0] || !i2c_kt[1]);
	JUDGE_VT(STD_890_M_SER_KT, 0);
	JUDGE_VT(STD_890_M_DES_KT, 1);
	
//	SEQ4	SPIпњљ РMпњљпњљпњљxпњљmпњљF
//	SEQ5	SPIпњљ РMпњљпњљпњљxпњљmпњљF
	
	bool retryFlag = false;
	
	WAIT(3000);
	// пњљ«ВЁОћВпњљ
	ETH_BASE_RECV(0, false);
	ETH_MID_RECV(0, false);
	
	fVTValue[0] = 0;
	
	// MidпњљFspi_kt_mid
	ETH_MID_SEND("./" CMD_spi_kt_mid);
	
	// BaseпњљFspi_kt_base
	ETH_BASE_SEND("./" CMD_spi_kt_base);
	
	timeChecker.StartCheckTime();
	do
	{
		if (10 < timeChecker.CheckTime())
		{
			Print("spi mid Response Timeout");
			AbortNG();
		}
		
		ETH_MID_RECV(ETH_TIMEOUT, false);
	}
	while (ETH_MID_CHKRECV(RES_spi_kt_mid, false));
	
	ETH_MID_RESETPOINTER();
	while (ETH_MID_CHKRECV(RES_default, false))
	{
		ETH_MID_RECV(ETH_TIMEOUT, false);
	}
	
	timeChecker.StartCheckTime();
	do
	{
		if (!retryFlag && (5 < timeChecker.CheckTime()))
		{
			retryFlag = true;
			Print("spi mid send retry");
			ETH_MID_SEND("./" CMD_spi_kt_mid);
		}
		if (10 < timeChecker.CheckTime())
		{
			Print("spi base Response Timeout");
			AbortNG();
		}
		
		ETH_BASE_RECV(ETH_TIMEOUT, false);
	}
	while (ETH_BASE_CHKRECV(RES_spi_kt_base, false));
	fVTValue[0] = ETH_BASE_GETDECIMAL("Mbps");
	
	ETH_BASE_RESETPOINTER();
	while (ETH_BASE_CHKRECV(RES_default, false))
	{
		ETH_BASE_RECV(ETH_TIMEOUT, false);
	}
	
	if (retryFlag)
	{
		ETH_MID_CTRLC();
		do
		{
			ETH_MID_RECV(ETH_TIMEOUT, false);
		}
		while (ETH_MID_CHKRECV(RES_default, false));
	}
	
	JUDGE_VT(STD_890_B_SPI_KT, 0);
	
EndStep


