	IMAGE_OUTPUT("GVIF1-4", 0);
	WAIT(1000);	// DEBUG: post-wait IMAGE_OUTPUT GVIF1-4
	
//	SEQ13	пњљжСЬпњљoпњљЌБiPVMFrпњљj
	
	// пњљпњљ45
	WAIT(1000);	// DEBUG: pre-wait IMAGE_OUTPUT GVIF1-5
	IMAGE_OUTPUT("GVIF1-5", 0);
	WAIT(1000);	// DEBUG: post-wait IMAGE_OUTPUT GVIF1-5
	
//	SEQ14	пњљжСЬпњљoпњљЌБiPVMLhпњљj
	
	// пњљпњљ45
	WAIT(1000);	// DEBUG: pre-wait IMAGE_OUTPUT GVIF1-6
	IMAGE_OUTPUT("GVIF1-6", 0);
	WAIT(1000);	// DEBUG: post-wait IMAGE_OUTPUT GVIF1-6
	
//	SEQ15	пњљжСЬпњљoпњљЌБiPVMRhпњљj
	
	// пњљпњљ45
	WAIT(1000);	// DEBUG: pre-wait IMAGE_OUTPUT GVIF1-7
	IMAGE_OUTPUT("GVIF1-7", 0);
	WAIT(1000);	// DEBUG: post-wait IMAGE_OUTPUT GVIF1-7
	
	WAIT(3000);
	
	// mipiпњљnпњљпњљпњљhпњљVпњљFпњљCпњљNпњљпњљпњљпњљпњљmпњљF
	ETH_BASE_RECV(0, false);
	ETH_MID_RECV(0, false);
	
	if (!check_dmc)
	{
		if (ETH_BASE_CHKRECV("[init]CXD4966(Des_FRONT, T-PVM1) ", false) == 0)
		{
			if (strncmp(base_bufP, message_sequence_ok, sizeof(message_sequence_ok)) == 0)
			{
				fVTValue[0] = 1;
				check_dmc = true;
//				Print("mipi init DMC OK");
			}
			else
			{
				fVTValue[0] = 0;
				check_dmc = true;
				Print("mipi init TPVM1 NG");
			}
		}
		else
		{
			fVTValue[0] = -1;
			Print("mipi init TPVM1 result message is not found.");
		}
	}
	ETH_BASE_RESETPOINTER();
	
	if (!check_mm)
	{
		if (ETH_MID_CHKRECV("[init]CXD4967(Ser_MM) ", false) == 0)
		{
			if (strncmp(mid_bufP, message_sequence_ok, sizeof(message_sequence_ok)) == 0)
			{
				fVTValue[1] = 1;
				check_mm = true;
//				Print("mipi init MM OK");
			}
			else
			{
				fVTValue[1] = 0;
				check_mm = true;
				Print("mipi init MM NG");
			}
		}
		else
		{
			fVTValue[1] = -1;
			Print("mipi init MM result message is not found.");
		}
	}
	ETH_MID_RESETPOINTER();
	
	if (!check_pvm)
	{
		if (ETH_MID_CHKRECV("[init]CXD4964(Des_PVM) ", false) == 0)
		{
			if (strncmp(mid_bufP, message_sequence_ok, sizeof(message_sequence_ok)) == 0)
			{
				fVTValue[2] = 1;
				check_pvm = true;
//				Print("mipi init PVM OK");
			}
			else
			{
				fVTValue[2] = 0;
				check_pvm = true;
				Print("mipi init PVM NG");
			}
		}
		else
		{
			fVTValue[2] = -1;
			Print("mipi init PVM result message is not found.");
		}
	}
	ETH_MID_RESETPOINTER();
	
	Judge(fVTValue[0], "=", 1, "", "MIPI_TPVM1", 0, "", true);
	JudgeCounter::GetInstance().CountUp(1);
	Judge(fVTValue[1], "=", 1, "", "MIPI_MM", 0, "", true);
	JudgeCounter::GetInstance().CountUp(1);
	Judge(fVTValue[2], "=", 1, "", "MIPI_PVM", 0, "", true);
	JudgeCounter::GetInstance().CountUp(1);
	
EndStep


/*-----------------------------------------------------
	STEP 630 
-----------------------------------------------------*/
StartStep 630, 60000, cmTimeoutAbort
#include	LOCALPARAMS
#include	LOCALMACROS

	etherBaseLog.Write("////////// STEP 630 //////////");
	etherMidLog.Write("////////// STEP 630 //////////");
	
	bool controls[5];
	for (int i = 0; i < sizeof(controls); i++)
	{
		controls[i] = false;
	}
	
//	CONTROL1	GPIOпњљпњљпњљпњљ/пњљ«Пo
//	CONTROL2	GPIOпњљпњљпњљпњљ/пњљ«Пo
//	CONTROL3	GPIOпњљпњљпњљпњљ/пњљ«Пo
//	CONTROL4	GPIOпњљпњљпњљпњљ/пњљ«Пo
//	CONTROL5	GPIOпњљпњљпњљпњљ/пњљ«Пo
	
	// CONTROL1 BaseпњљFB_SOC_RST_TIMO_write_1
	// CONTROL3 BaseпњљFB_SOC_RPRG_JDG_write_1
	// CONTROL4 BaseпњљFB_SOC_SUF_JDG_write_1
	ETH_BASE_SEND(
		"./"  CMD_B_SOC_RST_TIMO_write_1			// CONTROL1
		"&./" CMD_B_SOC_RPRG_JDG_write_1			// CONTROL3
		"&./" CMD_B_SOC_SUF_JDG_write_1				// CONTROL4
		"&");
	// CONTROL2 MidпњљFM_SOC_RST_TIMI_write_1
	// CONTROL5 MidпњљFM_SOC_TIMESYNC_write_1
	ETH_MID_SEND(
		"./"  CMD_M_SOC_RST_TIMI_write_1			// CONTROL2
		"&./" CMD_M_SOC_TIMESYNC_write_1			// CONTROL5
		"&");
	
	do
	{
		ETH_BASE_RECV(ETH_TIMEOUT, false);
		ETH_MID_RECV(ETH_TIMEOUT, false);
		
		// CONTROL1 BaseпњљFB_SOC_RST_TIMO_write_1
		if (!controls[0])
		{
			ETH_BASE_RESETPOINTER();
			if (ETH_BASE_CHKRECV(RES_B_SOC_RST_TIMO_write_1, false) == 0)
			{
				controls[0] = true;
			}
		}
		
		// CONTROL2 MidпњљFM_SOC_RST_TIMI_write_1
		if (!controls[1])
		{
			ETH_MID_RESETPOINTER();
			if (ETH_MID_CHKRECV(RES_M_SOC_RST_TIMI_write_1, false) == 0)
			{
				controls[1] = true;
			}
		}
		
		// CONTROL3 BaseпњљFB_SOC_RPRG_JDG_write_1
		if (!controls[2])
		{
			ETH_BASE_RESETPOINTER();
			if (ETH_BASE_CHKRECV(RES_B_SOC_RPRG_JDG_write_1, false) == 0)
			{
				controls[2] = true;
			}
		}
		
		// CONTROL4 BaseпњљFB_SOC_SUF_JDG_write_1
		if (!controls[3])
		{
			ETH_BASE_RESETPOINTER();
