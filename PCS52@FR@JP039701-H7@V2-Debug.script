StartStep 625, 60000, cmTimeoutAbort
#include	LOCALPARAMS
#include	LOCALMACROS

	etherBaseLog.Write("////////// STEP 625 //////////");
	etherMidLog.Write("////////// STEP 625 //////////");
	
	int setParamResult = 0;
	bool check_dmc = false;
	bool check_mm = false;
	bool check_pvm = false;
	
	// пњљ«ВЁОћВпњљ
	ETH_BASE_RECV(0, false);
	ETH_MID_RECV(0, false);
	
//	SEQ1	пњљpпњљпњљпњљпњљпњљ[пњљ^пњљЁТпњљiMMпњљj
	
	for (int i = 0; i < 5; i++)
	{
		// пњљпњљ43
		setParamResult = gvif_setParams(GVIF_MODLE_IPADDR, 10, FILE_SETPARAM_MM);
		if (setParamResult != 0)
		{
			Print("setParam Error:%x", setParamResult);
			
			if (i != 4)
			{
				gvif_initialize(GVIF_MODLE_IPADDR, 1);
				
				ETH_BASE_SEND("./" CMD_B_mipi_init);
				ETH_MID_SEND("./" CMD_M_mipi_init);
				
				WAIT(1000);
			}
		}
		else
		{
			break;
		}
	}
	
	// DEBUG: handshake for GVIF1-4 after setParams, before OUTPUT_IMAGE_SET
	IMAGE_HANDSHAKE_SET("GVIF1-4", 30);
//	SEQ2	пњљoпњљЌЙжСЬпњљЁТпњљiFCMпњљj
	
