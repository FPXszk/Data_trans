	WAIT(1000);	// DEBUG: pre-wait IMAGE_OUTPUT GVIF1-1
	IMAGE_OUTPUT("GVIF1-1", 0);
	WAIT(1000);	// DEBUG: post-wait IMAGE_OUTPUT GVIF1-1
	
//	SEQ10	пњљжСЬпњљoпњљЌБiTPVM1пњљj
	
	// пњљпњљ45
	WAIT(1000);	// DEBUG: pre-wait IMAGE_OUTPUT GVIF1-3
	IMAGE_OUTPUT("GVIF1-3", 0);
	WAIT(1000);	// DEBUG: post-wait IMAGE_OUTPUT GVIF1-3
	
//	SEQ12	пњљжСЬпњљoпњљЌБiPVMRrпњљj
	
