StartStep 605, 60000, cmTimeoutAbort
#include	LOCALPARAMS
#include	LOCALMACROS

	etherBaseLog.Write("////////// STEP 605 //////////");
	etherMidLog.Write("////////// STEP 605 //////////");
	
	bool ctrl41ck[2];
	for (int i = 0; i < sizeof(ctrl41ck); i++)
	{
		ctrl41ck[i] = false;
	}
	
//	SEQ1	SPIпњљ РM
	
	// BaseпњљFB_SPI_SoC_ck
	ETH_BASE_SEND("./" CMD_B_SPI_SoC_ck);
	
	do
	{
		ETH_BASE_RECV(ETH_TIMEOUT, false);
		
		// 1пњљsпњљпњљ
		if (!ctrl41ck[0])
		{
			ETH_BASE_RESETPOINTER();
			if (ETH_BASE_CHKRECV(RES_B_SPI_SoC_ck_1, false) == 0)
			{
				// пњљпњљ18пњљF2пњљsпњљ∆ВпњљOKпњљ»Впњљ1
				if (ETH_BASE_GETOKNG() == 1)
				{
					fVTValue[0] = 1;
				}
				else
				{
					fVTValue[0] = 0;
				}
				ctrl41ck[0] = true;
			}
		}
		// 2пњљsпњљпњљ
		if (ctrl41ck[0] && !ctrl41ck[1])
		{
			if (fVTValue[0] == 1)
			{
				ETH_BASE_RESETPOINTER();
				if (ETH_BASE_CHKRECV(RES_B_SPI_SoC_ck_2, false) == 0)
				{
					// пњљпњљ18пњљF2пњљsпњљ∆ВпњљOKпњљ»Впњљ1
					if (ETH_BASE_GETOKNG() == 1)
					{
						fVTValue[0] = 1;
					}
					else
					{
						fVTValue[0] = 0;
					}
					ctrl41ck[1] = true;
				}
			}
			else
			{
				// 1пњљsпњљЏВпњљпњљпњљпњљпњљNG
				ctrl41ck[1] = true;
			}
		}
	}
	while (!ctrl41ck[0] || !ctrl41ck[1]);
	JUDGE_VT(STD_605_B_M_SPI, 0);
	
EndStep


