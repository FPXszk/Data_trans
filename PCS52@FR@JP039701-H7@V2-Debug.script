/*-----------------------------------------------------
	Part Finalize STEP
-----------------------------------------------------*/
PartFinalStep
#include	LOCALPARAMS
#include	INITMACROS
#include	LOCALMACROS
// FinalStepпњљ≈ВћСпњљпњљdincludeпњљhпњљ~
#define		FINAL_INC_LOCALPARAMS
#define		FINAL_INC_INITMACROS
#define		FINAL_INC_LOCALMACROS
	
	etherBaseLog.Write("////////// STEP PartFinal //////////");
	etherMidLog.Write("////////// STEP PartFinal //////////");
	
	// POW
	USB_POW_VOLT(PWR1, 0.0);
	USB_POW_VOLT(PWR3, 0.0);
	USB_POW_OUTP(PWR1, "OFF");
	USB_POW_OUTP(PWR3, "OFF");
	WAIT(POW_WAIT);
	USB_POW_OUTP_PROT_CLE(PWR1);
	USB_POW_OUTP_PROT_CLE(PWR3);
	
	// ADC
	ADC32_INIT();
	// CAN-FD
	CANFD_USB_INIT();
	
	// пњљZпњљпњљпњљVпњљпњљпњљO
	// RLY_SET(PATH_RY0_13, "off");
	
	// RY
	USBPO128RLY_INIT();
	
	// USB Close
	CLOSE_USB(PWR1);
	CLOSE_USB(PWR3);
	CLOSE_DEFAULT_RM();
	
	// STEPпњљпњљ≈Тпњљ~пњљпњљпњљƒВпњљпњљйВ™пњљAпњљпњљпњљfпњљпњљпњљпњљпњљкНЗпњљпњљzпњљиВµпњљƒТпњљ~
	gvif_stopOutputImage(GVIF_MODLE_IPADDR, 1);
	gvif_stopOutputImage(GVIF_MODLE_IPADDR, 3);
	gvif_stopOutputImage(GVIF_MODLE_IPADDR, 4);
	gvif_stopOutputImage(GVIF_MODLE_IPADDR, 5);
	gvif_stopOutputImage(GVIF_MODLE_IPADDR, 6);
	gvif_stopOutputImage(GVIF_MODLE_IPADDR, 7);
	gvif_disconnectDevice(GVIF_MODLE_IPADDR);
	
	if (gvifRestart)
	{
		Print("GVIF Restart");
		// пњљќМпњљпњљ@пњљпњљпњљZпњљbпњљg
		gvif_connectDevice(GVIF_MODLE_IPADDR, GVIF_MODLE_IPPORT);
		gvif_initialize(GVIF_MODLE_IPADDR, 0);
		gvif_disconnectDevice(GVIF_MODLE_IPADDR);
		WAIT(60000);
	}
	
	// Ether
	ETH_BASE_RECV(0, false);
	ETH_MID_RECV(0, false);
	etherBase.Close();
	etherMid.Close();
	
EndStep


/*-----------------------------------------------------
	Finalize STEP
-----------------------------------------------------*/
FinalStep
EndStep


EndTestDescription
