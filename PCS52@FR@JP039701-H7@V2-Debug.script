StartStep 700, 60000, cmTimeoutAbort
#include	LOCALPARAMS
#include	LOCALMACROS

	etherBaseLog.Write("////////// STEP 700 //////////");
	etherMidLog.Write("////////// STEP 700 //////////");
	
	bool controls[3];
	for (int i = 0; i < sizeof(controls); i++)
	{
		controls[i] = false;
	}
	
//	CONTROL1	GPIOпњљпњљпњљпњљ/пњљ«Пo
//	CONTROL2	GPIOпњљпњљпњљпњљ/пњљ«Пo
	
	// пњљпњљ39
	// CONTROL1 MidпњљFM_DSIPWR_EN_on
	// CONTROL2 MidпњљFM_VSUP1_EN_off
	ETH_MID_SEND(
		"./"  CMD_M_DSIPWR_EN_on
		"&./" CMD_M_VSUP1_EN_off
		"&");
	do
	{
		ETH_MID_RECV(ETH_TIMEOUT, false);
		
		// CONTROL1 MidпњљFM_DSIPWR_EN_on
		if (!controls[0])
		{
			ETH_MID_RESETPOINTER();
			if (ETH_MID_CHKRECV(RES_M_DSIPWR_EN_on, false) == 0)
			{
				controls[0] = true;
			}
		}
		
		// CONTROL2 MidпњљFM_VSUP1_EN_off
		if (!controls[1])
		{
			ETH_MID_RESETPOINTER();
			if (ETH_MID_CHKRECV(RES_M_VSUP1_EN_off, false) == 0)
			{
				controls[1] = true;
			}
		}
	}
	while (
		   !controls[0]
		|| !controls[1]
		);
	
//	CONTROL3	GPIOпњљпњљпњљпњљ/пњљ«Пo
	
	// CONTROL3 MidпњљFM_VSUP2_EN_off
	ETH_MID_SEND("./" CMD_M_VSUP2_EN_off);
	do
	{
		ETH_MID_RECV(ETH_TIMEOUT, false);
	}
	while (ETH_MID_CHKRECV(RES_M_VSUP2_EN_off, false));
	
EndStep


