		}
	}
	while (ETH_MID_CHKRECV(RES_default, false));	// mipiпњљпњљпњљпњљпњљпњљпњљпњљпњљƒВпњљпњљ»Впњљпњљ∆Кпњљпњљ“Йпњљпњљпњљпњљпњљпњљ»ВпњљпњљћВ≈ГfпњљtпњљHпњљпњљпњљgпњљ“Впњљ
	JUDGE_VT(STD_722_OPP_PVM, 0);
	
//	SEQ1	пњљOпњљпњљпњљJпњљпњљпњљпњљпњљAпњљhпњљпњљпњљпњљпњљjпњљpDESпњљпњљFSYNCпњљMпњљпњљпњљЁТпњљ
//	SEQ2	пњљOпњљпњљпњљJпњљпњљпњљпњљпњљAпњљhпњљпњљпњљпњљпњљjпњљpDESпњљпњљFSYNCпњљMпњљпњљпњљmпњљF
	
