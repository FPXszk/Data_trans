	WAIT(1000);	// DEBUG: pre-wait OUTPUT_IMAGE_SET GVIF1-4
	OUTPUT_IMAGE_SET("GVIF1-4", FILE_OUTPUT_REAR);
	WAIT(1000);	// DEBUG: post-wait OUTPUT_IMAGE_SET GVIF1-4
	
//	SEQ6	пњљoпњљЌЙжСЬпњљЁТпњљiPVMFrпњљj
	
