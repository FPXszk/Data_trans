	while (ETH_BASE_CHKRECV(RES_default, false));	// mipiпњљпњљпњљпњљпњљпњљпњљпњљпњљƒВпњљпњљ»Впњљпњљ∆Кпњљпњљ“Йпњљпњљпњљпњљпњљпњљ»ВпњљпњљћВ≈ГfпњљtпњљHпњљпњљпњљgпњљ“Впњљ
	JUDGE_VT(STD_722_OPP_FCM, 0);
	
