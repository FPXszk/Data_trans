		gvif_chkInputImage(imgCompare);
		Print("mm result:0x%x, 0x%x", imgCompare[0], imgCompare[1]);
		// пњљпњљ49пњљFпњљќМпњљпњљ@пњљпњљпњљпњљпњљпњљ0x1пњљ»Впњљ1
